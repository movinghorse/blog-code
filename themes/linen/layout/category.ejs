<section class="archive-head">
  <p class="eyebrow"><%= __('category') %></p>
  <h1><%= page.category %></h1>
</section>

<section class="post-list archive-list" aria-label="Category posts">
  <% page.posts.each(function(post){ %>
    <%- partial('_partial/post_list_item', {post: post}) %>
  <% }); %>
</section>

<%- partial('_partial/pagination') %>
