<section class="archive-head">
  <p class="eyebrow"><%= __('tag') %></p>
  <h1><%= page.tag %></h1>
</section>

<section class="post-list archive-list" aria-label="Tag posts">
  <% page.posts.each(function(post){ %>
    <%- partial('_partial/post_list_item', {post: post}) %>
  <% }); %>
</section>

<%- partial('_partial/pagination') %>
