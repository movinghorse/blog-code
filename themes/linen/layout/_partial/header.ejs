<header class="site-header">
  <a class="brand" href="<%- url_for('/') %>" aria-label="<%= config.title %>">
    <span class="brand-title"><%= config.title %></span>
    <% if (config.subtitle){ %><span class="brand-subtitle"><%= config.subtitle %></span><% } %>
  </a>
  <nav class="site-nav" aria-label="Main navigation">
    <% Object.keys(theme.menu || {}).forEach(function(name){ %>
      <a href="<%- url_for(theme.menu[name] || '/') %>"><%= name %></a>
    <% }); %>
  </nav>
</header>
